AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview

AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your_embedding_deployment_name
AZURE_OPENAI_CHAT_DEPLOYMENT=your_chat_deployment_name

CHROMA_PATH=./db/chroma_store
CHROMA_COLLECTION=nordtrail_service_client

DOCUMENTS_PATH=./documents
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# ==================== AZURE OPENAI ====================
# Clé API Azure OpenAI (obtenue via Azure CLI)
AZURE_OPENAI_API_KEY=your-openai-api-key-here

# Endpoint Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://canadacentral.api.cognitive.microsoft.com/

# Version de l'API (optionnel)
AZURE_OPENAI_API_VERSION=2024-02-01

# Noms des modèles déployés dans votre ressource Azure OpenAI
AZURE_OPENAI_EMBEDDING_MODEL=mon-embedding
AZURE_OPENAI_CHAT_MODEL=mon-llm-chat

# ==================== AZURE AI SEARCH ====================
# Clé API Azure AI Search
AZURE_SEARCH_API_KEY=your-search-api-key-here

# Endpoint Azure AI Search
AZURE_SEARCH_ENDPOINT=https://mon-moteur-search.search.windows.net

# Nom de l'index de recherche
AZURE_SEARCH_INDEX_NAME=index-rag-canadien

# ==================== CHROMA (Local Vector Store - Optionnel) ====================
# Chemin de stockage local pour Chroma
CHROMA_PATH=./db/chroma_store

# Nom de la collection Chroma
CHROMA_COLLECTION=nordtrail_documents

# ==================== DOCUMENT INGESTION ====================
# Dossier contenant les documents à ingérer
DOCUMENTS_FOLDER=./documents

# Taille des chunks de texte (en caractères)
CHUNK_SIZE=1500

# Chevauchement entre les chunks (en caractères)
CHUNK_OVERLAP=150

# ==================== DEBUG ====================
# Mode debug (true/false)
DEBUG_MODE=false
