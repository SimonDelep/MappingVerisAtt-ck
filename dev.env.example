# Copie ce fichier en `dev.env` et renseigne tes valeurs.
# `dev.env` ne doit jamais être commité (secrets).

# ==================== MODE D'EXÉCUTION ====================
# "local" (défaut) : embeddings sentence-transformers, aucune clé requise.
# "azure" : embeddings + LLM Azure OpenAI.
RAG_PROVIDER=local
# RAG_GENERATOR=retrieval   # retrieval | local_llm | llm

# ==================== AZURE OPENAI (si RAG_PROVIDER=azure) ====================
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Noms des DÉPLOIEMENTS Azure (pas des modèles)
AZURE_OPENAI_EMBEDDING_MODEL=your-embedding-deployment
AZURE_OPENAI_CHAT_MODEL=your-chat-deployment

# ==================== RAG (optionnel) ====================
# RAG_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RAG_TOP_K_TECHNIQUES=20
# RAG_TOP_M_EXAMPLES=5
# RAG_RETRIEVAL_SIM_HIGH=0.50
# RAG_RETRIEVAL_SIM_MED=0.38
